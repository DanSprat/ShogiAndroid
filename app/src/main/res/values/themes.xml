<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Shogi" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/shogi_amber</item>
        <item name="colorPrimaryVariant">@color/shogi_amber_dark</item>
        <item name="colorOnPrimary">@color/menu_button_fill_text</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/time_tile_bg_elevated</item>
        <item name="colorSecondaryVariant">@color/time_tile_bg</item>
        <item name="colorOnSecondary">@color/time_tile_text_primary</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/time_gradient_end</item>
        <!-- Системная панель навигации — тот же тон, что низ градиента (иначе чёрная полоса). -->
        <item name="android:navigationBarColor" tools:targetApi="l">@color/time_gradient_end</item>
        <item name="android:windowBackground">@color/time_gradient_end</item>
        <!-- Без автоматической «подложки» под nav bar — иначе видна полоска другого оттенка. -->
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:navigationBarDividerColor" tools:targetApi="p">@android:color/transparent</item>
        <!-- Customize your theme here. -->
    </style>

    <declare-styleable name="ShogiView">
        <attr name="noteSize" format="integer"></attr>
        <attr name="separateLineSize" format="integer"></attr>
    </declare-styleable>

    <declare-styleable name="ViewMoves">
        <attr name="cellSize" format="integer"></attr>
        <attr name="lineSize" format="integer"></attr>
        <attr name="boardSize" format="integer"></attr>
    </declare-styleable>

    <declare-styleable name="BundleView">
        <attr name="boardSZ" format="integer"></attr>
        <attr name="isLower" format="integer"></attr>
    </declare-styleable>

    <declare-styleable name="CountsView">
        <attr name="board" format="integer"></attr>
        <attr name="inLow" format="integer"></attr>
    </declare-styleable>
    <declare-styleable name="TestVies">
        <attr name="test" format="integer"></attr>
    </declare-styleable>

    <declare-styleable name="WhiteCanvasView">
        <attr name="boardWidth" format="integer"></attr>
        <attr name="line" format="integer"></attr>
        <attr name="cell" format="integer"></attr>
    </declare-styleable>

    <attr name="relation" format="float"/>

</resources>