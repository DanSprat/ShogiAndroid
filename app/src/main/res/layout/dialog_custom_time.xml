<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.2"
            android:text="@string/custom_time_hint"
            android:textColor="#AA1A1C22"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:labelFor="@id/np_minutes"
            android:text="@string/minutes"
            android:textColor="#FF1A1C22"
            android:textSize="15sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/dialog_custom_time_well"
            android:paddingVertical="4dp">

            <NumberPicker
                android:id="@+id/np_minutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:theme="@style/CustomTimeNumberPickerTheme" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:labelFor="@id/np_increment"
            android:text="@string/seconds_per_move"
            android:textColor="#FF1A1C22"
            android:textSize="15sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/dialog_custom_time_well"
            android:paddingVertical="4dp">

            <NumberPicker
                android:id="@+id/np_increment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:theme="@style/CustomTimeNumberPickerTheme" />
        </FrameLayout>
    </LinearLayout>
</ScrollView>
