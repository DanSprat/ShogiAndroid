<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_time_select_gradient">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.055"
        android:contentDescription="@null"
        android:scaleType="center"
        android:src="@drawable/bishop_0" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/time_select_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/time_select_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.03"
                android:text="@string/time_control_title"
                android:textColor="@color/time_tile_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/time_select_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="@string/time_control_subtitle"
                android:textColor="@color/time_screen_header_muted"
                android:textSize="15sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <View
                    android:id="@+id/time_select_divider"
                    android:layout_width="120dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@color/time_tile_accent_bar" />
            </FrameLayout>

            <!-- Верхний ряд: подписи по краям, в центре «мин + сек» в рамках -->
            <LinearLayout
                android:id="@+id/time_values_header_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/label_minutes_per_game"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:maxLines="4"
                    android:text="@string/time_minutes_per_game"
                    android:textColor="@color/time_screen_header_muted"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/value_minutes"
                        android:layout_width="48dp"
                        android:layout_height="44dp"
                        android:background="@drawable/time_value_box"
                        android:gravity="center"
                        android:textColor="@color/time_tile_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="6dp"
                        android:text="+"
                        android:textColor="@color/time_screen_header_muted"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/value_increment"
                        android:layout_width="48dp"
                        android:layout_height="44dp"
                        android:background="@drawable/time_value_box"
                        android:gravity="center"
                        android:textColor="@color/time_tile_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="3" />
                </LinearLayout>

                <TextView
                    android:id="@+id/label_increment_per_move"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:maxLines="4"
                    android:text="@string/time_seconds_increment_per_move"
                    android:textColor="@color/time_screen_header_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Два ползунка в двух колонках под значениями -->
            <LinearLayout
                android:id="@+id/time_sliders_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatSeekBar
                    android:id="@+id/seek_minutes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="90"
                    android:paddingStart="0dp"
                    android:paddingEnd="6dp"
                    android:progressBackgroundTint="@color/time_seek_track"
                    android:progressTint="@color/time_preset_chip_selected"
                    android:thumbTint="@color/time_seek_thumb" />

                <androidx.appcompat.widget.AppCompatSeekBar
                    android:id="@+id/seek_increment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="30"
                    android:paddingStart="6dp"
                    android:paddingEnd="0dp"
                    android:progressBackgroundTint="@color/time_seek_track"
                    android:progressTint="@color/time_preset_chip_selected"
                    android:thumbTint="@color/time_seek_thumb" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:clipToPadding="false"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/time_preset_chip_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp" />
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_time"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:minHeight="52dp"
                android:text="@string/play"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/shogi_amber"
                app:cornerRadius="14dp"
                app:rippleColor="@color/menu_button_primary_ripple" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
