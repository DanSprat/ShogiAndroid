<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_menu"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/time_gradient_end">

    <ImageView
        android:id="@+id/menu_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/a833bb6d4c71af2e33021" />

    <View
        android:id="@+id/menu_legacy_soften"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/menu_legacy_photo_overlay"
        android:visibility="gone" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/menu_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="28dp">

        <ImageView
            android:id="@+id/menu_logo"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:layout_marginTop="32dp"
            android:contentDescription="@string/menu_logo_desc"
            android:elevation="12dp"
            android:padding="4dp"
            android:src="@drawable/menu_logo_bishop"
            android:translationZ="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/menu_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="6dp"
            android:elevation="2dp"
            android:fontFamily="@font/holtwood_one_sc"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:lineSpacingExtra="-2dp"
            android:shadowColor="#B0000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="16"
            android:text="@string/menu_title"
            android:textAlignment="center"
            android:textColor="@color/menu_title_on_plate"
            android:textSize="30sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/menu_logo" />

        <LinearLayout
            android:id="@+id/menu_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/one_device"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:text="@string/menu_play_local"
                android:textAllCaps="false"
                android:textColor="@color/menu_button_fill_text"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/menu_button_fill"
                app:cornerRadius="14dp"
                app:elevation="3dp"
                app:icon="@drawable/smartphone"
                app:iconGravity="textStart"
                app:iconPadding="14dp"
                app:iconTint="@color/menu_button_fill_text"
                app:rippleColor="@color/menu_button_primary_ripple" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/online_game"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="56dp"
                android:text="@string/menu_play_online"
                android:textAllCaps="false"
                android:textColor="@color/menu_button_secondary_text"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/menu_button_secondary"
                app:cornerRadius="14dp"
                app:elevation="2dp"
                app:icon="@drawable/socials"
                app:iconGravity="textStart"
                app:iconPadding="14dp"
                app:iconTint="@color/menu_button_secondary_text"
                app:rippleColor="@color/menu_button_secondary_ripple"
                app:strokeColor="@color/menu_button_secondary_stroke"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
