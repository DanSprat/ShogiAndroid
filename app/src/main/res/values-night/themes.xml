<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Shogi" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/shogi_amber</item>
        <item name="colorPrimaryVariant">@color/shogi_amber_dark</item>
        <item name="colorOnPrimary">@color/menu_button_fill_text</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/time_tile_bg_elevated</item>
        <item name="colorSecondaryVariant">@color/time_tile_bg</item>
        <item name="colorOnSecondary">@color/time_tile_text_primary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/time_gradient_end</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/time_gradient_end</item>
        <item name="android:windowBackground">@color/time_gradient_end</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:navigationBarDividerColor" tools:targetApi="p">@android:color/transparent</item>
        <!-- Customize your theme here. -->
    </style>
</resources>